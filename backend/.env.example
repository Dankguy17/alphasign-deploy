# ─────────────────────────────────────────────────────────────
# Band platform connection
# These two are fixed platform URLs — copy as-is.
# ─────────────────────────────────────────────────────────────
THENVOI_WS_URL=wss://app.band.ai/api/v1/socket/websocket
THENVOI_REST_URL=https://app.band.ai

# ─────────────────────────────────────────────────────────────
# LLM Providers
# ─────────────────────────────────────────────────────────────

# Featherless — open-source model inference (OpenAI-compatible)
# Get key from: https://featherless.ai/ (account dashboard)
FEATHERLESS_API_KEY=your_featherless_api_key_here
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
LATENT_STATE_MODEL=deepseek-ai/DeepSeek-V4-Pro

# AI/ML API — broader hosted-model catalog (OpenAI-compatible)
# Get key from: https://aimlapi.com/app/billing/
AIML_API_KEY=your_aiml_api_key_here
AIML_BASE_URL=https://api.aimlapi.com/v1

# ─────────────────────────────────────────────────────────────
# Market data sources (used by Signal Processing Agent)
# ─────────────────────────────────────────────────────────────
# FRED API — free, register at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# News API — used by Narrative Analyst Agent (e.g. Finnhub free tier or NewsAPI)
NEWS_API_KEY=your_news_api_key_here

# The "Signal Processing" Agent of choice
SIGNAL_OPINION_PROVIDER=gemini # Could be gemini, featherless, or aiml

# The "Signal Processing" agent's API key
GEMINI_API_KEY=your_gemini_api_key_here

# yfinance requires no API key.
