# ─────────────────────────────────────────────────────────────
# Band agent credentials — one entry per agent created on the
# Band dashboard (https://app.band.ai/agents -> New Agent -> Remote Agent).
#
# Each agent gets its own agent_id (UUID, shown in agent settings)
# and api_key (shown ONCE at creation time — copy it immediately).
#
# Copy this file to agent_config.yaml and fill in real values.
# agent_config.yaml is gitignored — never commit real keys.
# ─────────────────────────────────────────────────────────────

# Handle: @<your band username>/signal-processing
signal_processing:
  agent_id: "00000000-0000-0000-0000-000000000001"
  api_key: "band_api_ke_for_signal_processing"

# Handle: @<your band username>/narrative-analyst
narrative_analyst:
  agent_id: "00000000-0000-0000-0000-000000000002"
  api_key: "band_api_key_for_narrative_analyst"

# Handle: @<your band username>/latent-state
latent_state:
  agent_id: "00000000-0000-0000-0000-000000000003"
  api_key: "band_api_key_for_latent_state"

# Executive report generation runs locally and does not require a Band agent.
# To add an optional Executive participant to each room, set
# EXECUTIVE_AGENT_ID in .env.

# Band-only initiator. Separate from agents/executive report generation.
# Handle: @<your band username>/start-agent
start_agent:
  agent_id: "00000000-0000-0000-0000-000000000004"
  api_key: "band_api_key_for_start_agent"

# Test agent for development and testing (Gemini, free-tier)
# Handle: @<your band username>/my-agent
my_agent:
  agent_id: "00000000-0000-0000-0000-000000000005"
  api_key: "band_api_key_for_my_agent"
